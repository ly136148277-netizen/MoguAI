{
  "name": "ai-model-manager",
  "version": "2.0.1-rc.1",
  "description": "MOGU AI — Personal AI Control Center v2.0",
  "homepage": "https://github.com/ly136148277-netizen/MoguAI#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ly136148277-netizen/MoguAI.git"
  },
  "bugs": {
    "url": "https://github.com/ly136148277-netizen/MoguAI/issues"
  },
  "main": "src/main/main.js",
  "author": "MOGU AI",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/*.test.js",
    "screenshots": "electron scripts/capture-readme-screenshots.js",
    "acceptance": "node scripts/acceptance_v2.0.js",
    "acceptance:v1.4": "node scripts/acceptance_v1.4.0.js",
    "acceptance:v1.7": "node scripts/acceptance_v1.7.js",
    "acceptance:v2.0": "node scripts/acceptance_v2.0.js",
    "acceptance:v2.1": "node scripts/acceptance_v2.1.js",
    "acceptance:v2.2": "node scripts/acceptance_v2.2.js",
    "audit:v2.1-deps": "node scripts/audit_v21_dependencies.js",
    "evaluate:v2.1": "node scripts/run_v21_local_evaluation.js",
    "gates:v2.1": "node scripts/run_v21_gates.js",
    "acceptance:coding": "node scripts/acceptance_coding_bridge.js",
    "acceptance:moguai-coding": "node scripts/acceptance_coding_bridge.js",
    "bench:swe:fetch": "node scripts/bench_swe_fetch.js",
    "bench:swe:fetch-all": "node scripts/bench_swe_fetch_all.js",
    "bench:swe:fetch-verified": "node scripts/fetch_swe_verified.js",
    "bench:v2.1:freeze-holdout": "node scripts/freeze_v21_holdout.js",
    "bench:swe:sample": "node scripts/bench_swe_sample.js",
    "bench:swe:pull-images": "node scripts/bench_swe_pull_images.js",
    "bench:swe:run": "node scripts/bench_swe_run.js",
    "bench:swe:eval": "node scripts/bench_swe_eval.js",
    "bench:swe:bon-aggregate": "node scripts/bench_swe_bon_aggregate.js",
    "bench:probe-models": "node scripts/probe_relay_models.js",
    "bench:private:validate": "node scripts/bench_private_validate.js",
    "bench:private:run": "node scripts/bench_private_run.js",
    "bench:distill:convert": "python benchmarks/distill/convert_seed.py",
    "bench:distill:run": "python benchmarks/distill/run_distill.py",
    "coding:install-runtime": "node scripts/install_coding_runtime.js",
    "soak:beta": "node scripts/soak_v1.6_beta.js",
    "soak:v1.7": "node scripts/soak_v1.7.js",
    "soak:v2.0": "node scripts/soak_v2.0.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "check:asar": "node -e \"require('./build/asar-denylist').assertResourcesClean('dist/win-unpacked')\"",
    "check:public-profile": "node scripts/check_public_build_profile.js",
    "manifest:payload": "node scripts/generate_payload_manifest.js",
    "manifest:validate": "node scripts/validate_payload_manifest.js",
    "evidence:test": "node scripts/run_release_tests.js",
    "evidence:generate": "node scripts/generate_release_evidence.js",
    "evidence:validate": "node scripts/validate_release_evidence.js",
    "preflight:release": "npm test && npm run check:public-profile && npm run dist && npm run check:asar"
  },
  "keywords": [
    "electron",
    "llm",
    "gguf",
    "model-manager",
    "ollama",
    "local-ai",
    "mogu-ai",
    "MOGU AI",
    "desktop-app"
  ],
  "dependencies": {
    "axios": "^1.8.4",
    "electron-updater": "^6.8.9",
    "fs-extra": "^11.3.0",
    "monaco-editor": "^0.52.2",
    "node-pty": "1.1.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "rcedit": "^5.0.1"
  },
  "build": {
    "appId": "com.aimodel.manager",
    "productName": "MOGU AI",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "skills/**/*",
      "catalog/**/*",
      "assets/icon.png",
      "assets/icon.ico",
      "models.json",
      "package.json",
      "THIRD_PARTY_NOTICES.md",
      "config/prompts.json",
      "config/repository.json",
      "config/update.json",
      "config/skills-whitelist.json",
      "config/moguai-runtime-compat.json",
      "node_modules/monaco-editor/min/**/*",
      "node_modules/monaco-editor/package.json",
      "!config/**/*.token",
      "!config/**/*.env",
      "!config/mogu_*.json",
      "!config/xuzhou_*.json",
      "!**/secrets.json",
      "!**/.env",
      "!**/.env.*",
      "!scripts/**/*",
      "!**/*.token"
    ],
      "asarUnpack": [
        "node_modules/node-pty/**/*"
      ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://github.com/ly136148277-netizen/mogu-ai-releases/releases/"
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false,
      "signDlls": false
    },
    "afterPack": "build/afterPack.js",
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "shortcutName": "MOGU AI",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "menuCategory": false,
      "artifactName": "MOGU-AI-Setup-${version}.${ext}"
    }
  }
}
