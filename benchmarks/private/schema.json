{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MOGU private benchmark tasks",
  "description": "Self-owned or customer-authorized tasks only. Not for third-party non-public vendor datasets.",
  "type": "object",
  "required": ["version", "tasks"],
  "properties": {
    "version": { "type": "number" },
    "name": { "type": "string" },
    "note": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["prompt"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Alias of instance_id"
          },
          "instance_id": {
            "type": "string",
            "description": "Stable id, e.g. task_001"
          },
          "source": {
            "type": "string",
            "description": "Must be MOGUAI_PRIVATE (or omit). Vendor private sources rejected."
          },
          "difficulty": {
            "type": "string",
            "enum": ["easy", "medium", "hard"]
          },
          "prompt": {
            "type": "string",
            "description": "Task for mogu.coding (what to change)"
          },
          "workspace": {
            "type": "string",
            "description": "Absolute or repo-relative path to an existing git checkout"
          },
          "repo": {
            "type": "string",
            "description": "Optional github style owner/name if cloning"
          },
          "base_commit": {
            "type": "string",
            "description": "Optional commit to checkout before run"
          },
          "allowPaths": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional file-scope lock"
          },
          "success": {
            "type": "object",
            "properties": {
              "command": {
                "type": "string",
                "description": "Verify command, e.g. npm test"
              },
              "expectExitCode": { "type": "number", "default": 0 }
            }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
